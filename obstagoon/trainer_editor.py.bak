CONTROLLED_FIELD_ORDER = [
    'Name',
    'Pic',
    'Class',
    'Gender',
    'Items',
    'Music',
    'Battle Type',
    'Double Battle',
    'Mugshot',
    'Starting Status',
    'Pool Rules',
    'Party Size',
    'AI',
]

FIELD_NAME_MAP = {key.lower(): key for key in KNOWN_TRAINER_FIELDS}


def _normalize_trainer_field_key(raw_key: str) -> str:
    text = str(raw_key or '').strip()
    return FIELD_NAME_MAP.get(text.lower(), text)


def _parse_metadata_lines_preserving_values(lines: list[str]) -> dict[str, str]:
    result: dict[str, str] = {}
    for line in lines:
        if ':' not in line:
            continue
        raw_key, raw_value = line.split(':', 1)
        result[_normalize_trainer_field_key(raw_key)] = raw_value.strip()
    return result



STAT_ORDER = ['HP', 'Atk', 'Def', 'SpA', 'SpD', 'Spe']
NATURE_EFFECTS = {
    'Hardy': '', 'Lonely': '(+Atk, -Def)', 'Brave': '(+Atk, -Spe)', 'Adamant': '(+Atk, -SpAtk)', 'Naughty': '(+Atk, -SpDef)',
    'Bold': '(+Def, -Atk)', 'Docile': '', 'Relaxed': '(+Def, -Spe)', 'Impish': '(+Def, -SpAtk)', 'Lax': '(+Def, -SpDef)',
    'Timid': '(+Spe, -Atk)', 'Hasty': '(+Spe, -Def)', 'Serious': '', 'Jolly': '(+Spe, -SpAtk)', 'Naive': '(+Spe, -SpDef)',
    'Modest': '(+SpAtk, -Atk)', 'Mild': '(+SpAtk, -Def)', 'Quiet': '(+SpAtk, -Spe)', 'Bashful': '', 'Rash': '(+SpAtk, -SpDef)',
    'Calm': '(+SpDef, -Atk)', 'Gentle': '(+SpDef, -Def)', 'Sassy': '(+SpDef, -Spe)', 'Careful': '(+SpDef, -SpAtk)', 'Quirky': '',
}

def _normalize_lookup_key(value: str | None) -> str:
    text = fix_mojibake(str(value or '').strip()).lower()
    text = text.replace('’', "'")
    text = text.replace('-', '_').replace(' ', '_')
    text = text.replace("'", '')
    text = ''.join(ch for ch in text if ch.isalnum() or ch in {'_', '♀', '♂'})
    while '__' in text:
        text = text.replace('__', '_')
    return text.strip('_')

def _build_species_lookup(model: Any) -> dict[str, Any]:
    lookup = {}
    for species_id, rec in getattr(model, 'species', {}).items():
        keys = {species_id, rec.name, slug_from_symbol(species_id), slug_from_symbol(rec.name or ''), (rec.name or '').lower().replace(' ', '_')}
        for key in keys:
            norm = _normalize_lookup_key(key)
            if norm and norm not in lookup:
                lookup[norm] = rec
    return lookup

def _resolve_species_record(model: Any, value: str | None) -> Any | None:
    lookup = getattr(model, '_trainer_editor_species_lookup', None)
    if lookup is None:
        lookup = _build_species_lookup(model)
        setattr(model, '_trainer_editor_species_lookup', lookup)
    return lookup.get(_normalize_lookup_key(value))

def _display_graphics(site_generator: SiteGenerator, species: Any) -> dict[str, str]:
    return site_generator._display_graphics_for_species(species)

def _parse_natures(project_dir: Path) -> list[dict[str, str]]:
    text = _read_project_header(project_dir, 'include/constants/pokemon.h') or _read_project_header(project_dir, 'include/constants/battle.h')
    values = _parse_prefixed_symbols_anywhere(text, 'NATURE_')
    names=[]
    for value in values:
        human = _human_label(value, 'NATURE_')
        if human and human != 'Count' and human not in names:
            names.append(human)
    if not names:
        names = list(NATURE_EFFECTS)
    return [
        {
            'value': name,
            'label': f"{name} {NATURE_EFFECTS[name]}".strip(),
        }
        for name in names if name in NATURE_EFFECTS
    ]

def _parse_pool_tags(project_dir: Path) -> list[str]:
    text = _read_project_header(project_dir, 'include/trainer_pools.h')
    tags = []
    for symbol in _parse_prefixed_symbols_anywhere(text, 'POOL_TAG_'):
        if symbol in {'POOL_TAG_NONE', 'POOL_TAG_COUNT'}:
            continue
        human = _human_label(symbol, 'POOL_TAG_')
        if human and human not in tags:
            tags.append(human)
    return tags

def _parse_pokeballs(model: Any) -> list[str]:
    out=[]
    for rec in getattr(model, 'items', {}).values():
        name=getattr(rec,'name',None)
        pocket=str(getattr(rec,'pocket', '') or '')
        if name and ('poke ball' in pocket.lower() or pocket.upper()=='POCKET_POKE_BALLS'):
            out.append(name)
    return sorted(dict.fromkeys(out))


def _normalize_nature_value(value: str | None) -> str:
    text = str(value or '').strip()
    if not text:
        return ''
    if ' (' in text:
        text = text.split(' (', 1)[0].strip()
    if text.endswith(' Nature'):
        text = text[:-7].strip()
    return text


def _base_stat_map(stats: dict[str, Any] | None) -> dict[str, Any]:
    raw = dict(stats or {})
    alias = {
        'HP': ('HP', 'hp', 'baseHP', 'baseHp'),
        'Atk': ('Atk', 'atk', 'baseAttack'),
        'Def': ('Def', 'def', 'baseDefense'),
        'SpA': ('SpA', 'spa', 'spAtk', 'sp_atk', 'baseSpAttack'),
        'SpD': ('SpD', 'spd', 'spDef', 'sp_def', 'baseSpDefense'),
        'Spe': ('Spe', 'spe', 'speed', 'baseSpeed'),
    }
    out: dict[str, Any] = {}
    for target, candidates in alias.items():
        for key in candidates:
            if key in raw and raw[key] not in {None, ''}:
                out[target] = raw[key]
                break
    return out


def _species_asset_slugs(record: Any, model: Any) -> list[str]:
    slugs: list[str] = []
    seen: set[str] = set()

    def add(value: str | None) -> None:
        if not value:
            return
        cleaned = value.replace('SPECIES_', '').strip().lower()
        cleaned = cleaned.replace('♀', 'f').replace('♂', 'm')
        cleaned = cleaned.replace("'", '')
        cleaned = re.sub(r'[^a-z0-9]+', '_', cleaned).strip('_')
        if cleaned and cleaned not in seen:
            seen.add(cleaned)
            slugs.append(cleaned)

    add(getattr(record, 'species_id', None))
    add(getattr(record, 'name', None))
    base_species = getattr(record, 'base_species', None)
    if base_species:
        add(base_species)
        base = getattr(model, 'species', {}).get(base_species)
        if base:
            add(getattr(base, 'name', None))
            form_name = getattr(record, 'form_name', None)
            if form_name:
                add(f"{base.name}_{form_name}")
                add(f"{base.species_id.replace('SPECIES_', '')}_{form_name}")
    form_name = getattr(record, 'form_name', None)
    if form_name:
        add(form_name)
    return slugs


def _resolve_species_sprite_source(project_dir: Path, species: Any, graphics: dict[str, str] | None, model: Any) -> Path | None:
    graphics = graphics or {}
    candidates: list[Path] = []
    seen: set[Path] = set()

    def add(path: Path | None) -> None:
        if path is None:
            return
        path = path.resolve()
        if path not in seen:
            seen.add(path)
            candidates.append(path)

    for key in ('frontPic', 'frontPicFemale'):
        value = graphics.get(key) or getattr(species, 'graphics', {}).get(key)
        if value:
            value_str = str(value).replace('\\', '/')
            direct = project_dir / value_str
            add(direct if direct.exists() else None)
            source = Path(value_str)
            search_dirs = [source.parent]
            preferred = ['front.png', 'anim_front.png', 'front.webp', 'front.gif', 'front.jpg', 'front.jpeg']
            dynamic_stem = source.name[:-8] if source.name.endswith('.4bpp.lz') else Path(source.name).stem
            for parent in search_dirs:
                for name in preferred + [f'{dynamic_stem}{ext}' for ext in ['.png','.webp','.gif','.jpg','.jpeg'] if dynamic_stem and dynamic_stem not in {'front','anim_front'}]:
                    add(project_dir / parent / name)
    for slug in _species_asset_slugs(species, model):
        root = project_dir / 'graphics' / 'pokemon' / slug
        for name in ('front.png', 'anim_front.png', 'front.webp', 'front.gif', 'front.jpg', 'front.jpeg'):
            add(root / name)
    for candidate in candidates:
        if candidate.exists() and candidate.is_file():
            return candidate
    return None

def _species_details(site_generator: SiteGenerator, model: Any) -> dict[str, dict[str, Any]]:
    details={}
    for rec in getattr(model,'species',{}).values():
        teachable = [item.get('value') for item in getattr(rec.learnsets,'teachable',[]) if item.get('value')]
        details[rec.name]={
            'species_id': rec.species_id,
            'genderless': 'GENDERLESS' in str(getattr(rec,'gender_ratio', '') or '').upper(),
            'types': list(getattr(rec,'types',[]) or []),
            'abilities': list(dict.fromkeys([a for a in getattr(rec,'abilities',[]) if a])),
            'teachable_moves': list(dict.fromkeys(teachable)),
            'base_stats': _base_stat_map(getattr(rec,'stats',{})),
            'graphics': _display_graphics(site_generator, rec),
        }
    return details

def _parse_stat_line(value: str | None) -> dict[str, str]:
    out = {}
    for part in re.split(r'\s*/\s*', str(value or '').strip()):
        m = re.match(r'^(\d+)\s+([A-Za-z]+)$', part.strip())
        if m:
            out[m.group(2).replace('Spa','SpA').replace('Spd','SpD')] = m.group(1)
    return {k: out.get(k,'') for k in STAT_ORDER}

def _format_stat_line(stats: dict[str, Any] | None) -> str | None:
    if not stats:
        return None
    parts=[]
    for stat in STAT_ORDER:
        value = str((stats or {}).get(stat) or '').strip()
        if value != '':
            parts.append(f'{int(value)} {stat}')
    return ' / '.join(parts) or None

def _parse_pokemon_header(line: str) -> dict[str, str]:
    line = str(line or '').strip()
    held_item = None
    if ' @ ' in line:
        line, held_item = line.rsplit(' @ ',1)
    gender = ''
    m = re.search(r'\s*\(([MF])\)\s*$', line)
    if m:
        gender = m.group(1)
        line = line[:m.start()].strip()
    nickname = ''
    species = line.strip()
    m = re.match(r'^(.*?)\s*\((.*)\)$', line)
    if m:
        nickname = m.group(1).strip()
        species = m.group(2).strip()
    return {'species': species, 'nickname': nickname, 'gender': gender, 'held_item': (held_item or '').strip()}

def _parse_pokemon_block_editor(block: str) -> dict[str, Any]:
    lines=[line.rstrip() for line in str(block or '').splitlines() if line.strip()]
    if not lines:
        return {}
    header = _parse_pokemon_header(lines[0])
    mon = {'species': header['species'], 'nickname': header['nickname'], 'gender': header['gender'], 'shiny': '', 'tera_type': '', 'level': '', 'ball': header['held_item'], 'happiness': '', 'dynamax_level': '', 'gigantamax': '', 'ability': '', 'nature': '', 'moves': [], 'tags': [], 'ivs': {k:'' for k in STAT_ORDER}, 'evs': {k:'' for k in STAT_ORDER}}
    for line in lines[1:]:
        stripped=line.strip()
        if stripped.startswith('- '):
            move = stripped[2:].strip()
            if move:
                mon['moves'].append(move)
            continue
        if ':' in stripped:
            key, value = stripped.split(':',1)
            key = (title_case_words(key.strip()) or key.strip())
            value = value.strip()
            if key == 'Ability': mon['ability'] = value
            elif key == 'Level': mon['level'] = value
            elif key == 'Shiny': mon['shiny'] = 'Yes' if value.lower() == 'yes' else ('No' if value.lower() == 'no' else '')
            elif key == 'Tera Type': mon['tera_type'] = value
            elif key in {'Evs','EVs'}: mon['evs'] = _parse_stat_line(value)
            elif key in {'Ivs','IVs'}: mon['ivs'] = _parse_stat_line(value)
            elif key in {'Tags','Tag'}: mon['tags'] = [part.strip() for part in re.split(r'\s*/\s*', value) if part.strip()]
            elif key == 'Nature': mon['nature'] = _normalize_nature_value(value)
            elif key == 'Happiness': mon['happiness'] = value
            elif key == 'Dynamax Level': mon['dynamax_level'] = value
            elif key == 'Gigantamax': mon['gigantamax'] = 'Yes' if value.lower() == 'yes' else ('No' if value.lower() == 'no' else '')
        elif stripped.endswith(' Nature'):
            mon['nature'] = _normalize_nature_value(stripped[:-7].strip())
    mon['moves'] = (mon['moves'] + ['', '', '', ''])[:4]
    return mon

def _mon_is_effectively_empty(mon: dict[str, Any]) -> bool:
    return not str(mon.get('species') or '').strip()

def _serialize_pokemon_block(mon: dict[str, Any]) -> str | None:
    if _mon_is_effectively_empty(mon):
        return None
    species = str(mon.get('species') or '').strip()
    nickname = str(mon.get('nickname') or '').strip()
    gender = str(mon.get('gender') or '').strip()
    held_item = str(mon.get('ball') or '').strip()
    header = f'{nickname} ({species})' if nickname else species
    if gender in {'M','F'}:
        header += f' ({gender})'
    if held_item:
        header += f' @ {held_item}'
    lines=[header]
    fields=[('Ability', mon.get('ability')), ('Level', mon.get('level')), ('Shiny', mon.get('shiny')), ('Tera Type', mon.get('tera_type')), ('Happiness', mon.get('happiness')), ('Dynamax Level', mon.get('dynamax_level')), ('Gigantamax', mon.get('gigantamax'))]
    for key,val in fields:
        val=str(val or '').strip()
        if val:
            lines.append(f'{key}: {val}')
    evs = _format_stat_line(mon.get('evs'))
    if evs:
        lines.append(f'EVs: {evs}')
    nature = _normalize_nature_value(mon.get('nature'))
    if nature:
        lines.append(f'Nature: {nature}')
    ivs = _format_stat_line(mon.get('ivs'))
    if ivs:
        lines.append(f'IVs: {ivs}')
    tags = [str(t).strip() for t in (mon.get('tags') or []) if str(t).strip()]
    if tags:
        lines.append(f'Tags: {' / '.join(tags)}')
    for move in (mon.get('moves') or [])[:4]:
        move=str(move or '').strip()
        if move:
            lines.append(f'- {move}')
    return '\n'.join(lines)

